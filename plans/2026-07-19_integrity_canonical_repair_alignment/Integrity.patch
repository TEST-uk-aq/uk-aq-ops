+            for row in result_rows
+        ]
+    parquet_identities = Counter(
+        canonical_row_identity({
+            "connector_id": row[0],
+            "station_id": row[1],
+            "timeseries_id": row[2],
+            "pollutant_code": row[3],
+            "observed_at": row[4],
+            "value": row[5],
+            "status": row[6],
