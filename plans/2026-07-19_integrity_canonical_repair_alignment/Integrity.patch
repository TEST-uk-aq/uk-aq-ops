+        f"- Check only:{s['check_only']}",
+        f"- Run backfill: {s['run_backfill']}",
+        f"- DB:        {s['db_path']}",
+        f"- Log:       {s['log_path']}",
+        "",
+    ]
+
+    selection = s.get("date_selection") or {}
+    if selection:
+        lines.extend([
+            "## Date selection",
