+    if (
+        hashlib.sha256(source_rows_body).hexdigest()
+        != str(evidence.get("canonical_rows_sha256") or "")
+        or len(source_rows_body) != int(evidence.get("canonical_rows_bytes") or -1)
+        or len(source_rows) != int(evidence.get("total_rows") or 0)
+    ):
