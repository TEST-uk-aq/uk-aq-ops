# UK-AQ History Integrity — LIVE environment.
#
# Copy this file to the deployed root as:
#   /Users/mikehinford/uk-aq-history-integrity/env/LIVE.env
# then edit the BACKFILL_* paths to point at the local LIVE backfill tooling.
#
# Sourced by uk-aq-history-integrity.sh (auto-export via `set -a`).

UK_AQ_ENV_NAME="LIVE"

# Local-only state. SQLite DB, source-cache, tmp downloads, and the
# per-env lock MUST stay outside Dropbox to avoid WAL/SHM sync conflicts
# and partial-file races.
UK_AQ_HISTORY_INTEGRITY_ROOT="/Users/mikehinford/uk-aq-history-integrity"
UK_AQ_HISTORY_INTEGRITY_STATE_DIR="/Users/mikehinford/uk-aq-history-integrity/state/LIVE"
UK_AQ_HISTORY_INTEGRITY_DB_PATH="/Users/mikehinford/uk-aq-history-integrity/state/LIVE/uk_aq_history_integrity.sqlite"
UK_AQ_HISTORY_INTEGRITY_SOURCE_CACHE_DIR="/Users/mikehinford/uk-aq-history-integrity/state/LIVE/source-cache"
UK_AQ_HISTORY_INTEGRITY_TMP_DIR="/Users/mikehinford/uk-aq-history-integrity/state/LIVE/tmp"
UK_AQ_HISTORY_INTEGRITY_LOCK_DIR="/Users/mikehinford/uk-aq-history-integrity/state/LIVE/locks"

# Logs and reports are append-only / write-once text — safe on Dropbox.
# Pointed there so they can be tailed remotely without logging in to the host.
# To keep them local, swap back to .../state/LIVE/{logs,reports}.
UK_AQ_HISTORY_INTEGRITY_LOG_DIR="/Users/mikehinford/Dropbox/Apps/github-uk-air-quality-networks/LIVE/uk-aq-history-integrity/logs"
UK_AQ_HISTORY_INTEGRITY_REPORT_DIR="/Users/mikehinford/Dropbox/Apps/github-uk-air-quality-networks/LIVE/uk-aq-history-integrity/reports"

UK_AQ_HISTORY_INTEGRITY_DROPBOX_DB_COPY_PATH="/Users/mikehinford/Dropbox/Apps/github-uk-air-quality-networks/LIVE/uk-aq-history-integrity/uk_aq_history_integrity.sqlite"

UK_AQ_R2_HISTORY_DROPBOX_ROOT="/Users/mikehinford/Dropbox/Apps/github-uk-air-quality-networks/LIVE/r2-history"
UK_AQ_CORE_SNAPSHOT_DROPBOX_ROOT="/Users/mikehinford/Dropbox/Apps/github-uk-air-quality-networks/LIVE/r2-history/history/v1/core"

# Integrity backfill wrapper + env file. Set both before running with
# --run-backfill.
UK_AQ_HISTORY_INTEGRITY_BACKFILL_WRAPPER="/Users/mikehinford/Dropbox/Projects/CIC Website/CIC Air Quality Networks/LIVE UK AQ Networks/LIVE-uk-aq-ops/scripts/uk-aq-history-integrity/bin/uk_aq_integrity_backfill.sh"
UK_AQ_BACKFILL_ENV_FILE="/Users/mikehinford/Dropbox/Projects/CIC Website/CIC Air Quality Networks/LIVE UK AQ Networks/LIVE-uk-aq-ops/.env"

# Optional: cap timeseries IDs sent to the backfill wrapper in one subprocess
# call. 0 (or unset) = no chunking — the full union for a day (or per-(day,
# connector) pair for cross-check observation repair) is sent as one call
# (legacy behaviour, matches the per-call 30-minute timeout). When set to
# N>0, the union is sliced into chunks of <=N IDs and each chunk gets its own
# subprocess + 30-minute budget. Useful for weekly/monthly runs where a single
# day can have thousands of mismatches and would otherwise hit the timeout.
#UK_AQ_HISTORY_INTEGRITY_MAX_TIMESERIES_IDS_PER_BACKFILL=0
