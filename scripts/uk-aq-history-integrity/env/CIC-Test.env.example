# UK-AQ History Integrity — CIC-Test environment.
#
# Copy this file to the deployed root as:
#   /Users/mikehinford/uk-aq-history-integrity/env/CIC-Test.env
# then edit the BACKFILL_* paths to point at the local CIC-Test backfill tooling.
#
# Sourced by uk-aq-history-integrity.sh (auto-export via `set -a`).

UK_AQ_ENV_NAME="CIC-Test"

UK_AQ_HISTORY_INTEGRITY_PYTHON=/Users/mikehinford/uk-aq-history-integrity/.venv/bin/python

UK_AQ_OPS_REPO_ROOT="/Users/mikehinford/Dropbox/Projects/CIC Website/CIC Air Quality Networks/CIC-test-uk-aq-Operations/CIC-test-uk-aq-ops"

# Local-only state. SQLite DB, source-cache, tmp downloads, and the
# per-env lock MUST stay outside Dropbox to avoid WAL/SHM sync conflicts
# and partial-file races.
UK_AQ_HISTORY_INTEGRITY_ROOT="/Users/mikehinford/uk-aq-history-integrity"
UK_AQ_HISTORY_INTEGRITY_STATE_DIR="/Users/mikehinford/uk-aq-history-integrity/state/CIC-Test"
UK_AQ_HISTORY_INTEGRITY_DB_PATH="/Users/mikehinford/uk-aq-history-integrity/state/CIC-Test/uk_aq_history_integrity.sqlite"
UK_AQ_HISTORY_INTEGRITY_SOURCE_CACHE_DIR="/Users/mikehinford/uk-aq-history-integrity/state/CIC-Test/source-cache"
UK_AQ_HISTORY_INTEGRITY_TMP_DIR="/Users/mikehinford/uk-aq-history-integrity/state/CIC-Test/tmp"
UK_AQ_HISTORY_INTEGRITY_LOCK_DIR="/Users/mikehinford/uk-aq-history-integrity/state/CIC-Test/locks"

# Logs and reports are append-only / write-once text — safe on Dropbox.
# The main history-integrity runner uses UK_AQ_HISTORY_INTEGRITY_{LOG,REPORT}_DIR.
# The AQI gap checker uses UK_AQ_AQI_GAP_{LOG,REPORT}_DIR.
# To keep the main runner local, swap back to .../state/CIC-Test/{logs,reports}.
# To keep the AQI gap checker local, swap back to .../state/CIC-Test/aqi_gap_check/{logs,reports}.
UK_AQ_HISTORY_INTEGRITY_LOG_DIR="/Users/mikehinford/Dropbox/Apps/github-uk-air-quality-networks/CIC-Test/uk-aq-history-integrity/logs"
UK_AQ_HISTORY_INTEGRITY_REPORT_DIR="/Users/mikehinford/Dropbox/Apps/github-uk-air-quality-networks/CIC-Test/uk-aq-history-integrity/reports"
UK_AQ_AQI_GAP_LOG_DIR="/Users/mikehinford/Dropbox/Apps/github-uk-air-quality-networks/CIC-Test/uk-aq-history-integrity/aqi_gap_check/logs"
UK_AQ_AQI_GAP_REPORT_DIR="/Users/mikehinford/Dropbox/Apps/github-uk-air-quality-networks/CIC-Test/uk-aq-history-integrity/aqi_gap_check/reports"
UK_AQ_HISTORY_INTEGRITY_DROPBOX_DB_COPY_PATH="/Users/mikehinford/Dropbox/Apps/github-uk-air-quality-networks/CIC-Test/uk-aq-history-integrity/uk_aq_history_integrity.sqlite"

UK_AQ_R2_HISTORY_DROPBOX_ROOT="/Users/mikehinford/Dropbox/Apps/github-uk-air-quality-networks/CIC-Test/r2-history"
UK_AQ_CORE_SNAPSHOT_DROPBOX_ROOT="/Users/mikehinford/Dropbox/Apps/github-uk-air-quality-networks/CIC-Test/r2-history/history/v1/core"

# Integrity backfill wrapper + env file. Set both before running with
# --run-backfill.
UK_AQ_HISTORY_INTEGRITY_BACKFILL_WRAPPER="/Users/mikehinford/Dropbox/Projects/CIC Website/CIC Air Quality Networks/CIC-test-uk-aq-Operations/CIC-test-uk-aq-ops/scripts/uk-aq-history-integrity/bin/uk_aq_integrity_backfill.sh"
UK_AQ_BACKFILL_ENV_FILE="/Users/mikehinford/Dropbox/Projects/CIC Website/CIC Air Quality Networks/CIC-test-uk-aq-Operations/CIC-test-uk-aq-ops/.env"
UK_AQ_HISTORY_INTEGRITY_BACKUP_TASK_KEYS="ops.r2_history_dropbox_backup"
UK_AQ_HISTORY_INTEGRITY_BACKUP_READINESS_RPC="uk_aq_rpc_daily_task_backup_readiness"

# Daily task health reporting into Obs AQI DB daily_task_runs.
# Reads OBS_AQIDB_* credentials from UK_AQ_BACKFILL_ENV_FILE.
UK_AQ_HISTORY_INTEGRITY_DAILY_TASK_HEALTH_ENABLED=true
UK_AQ_HISTORY_INTEGRITY_DAILY_TASK_HEALTH_STRICT=false

# Optional: cap timeseries IDs sent to the backfill wrapper in one subprocess
# call. 0 (or unset) = no chunking — the full union for a day (or per-(day,
# connector) pair for cross-check observation repair) is sent as one call
# (legacy behaviour, matches the per-call 30-minute timeout). When set to
# N>0, the union is sliced into chunks of <=N IDs and each chunk gets its own
# subprocess + 30-minute budget. Useful for weekly/monthly runs where a single
# day can have thousands of mismatches and would otherwise hit the timeout.
# A value around 200 is a sensible starting point on CIC-Test.
UK_AQ_HISTORY_INTEGRITY_MAX_TIMESERIES_IDS_PER_BACKFILL=200

# When chunking is configured and a day/connector has > max IDs, try one
# unchunked observation-repair backfill first; fall back to chunked calls on
# failure/timeout.
UK_AQ_HISTORY_INTEGRITY_BACKFILL_TRY_UNCHUNKED_FIRST=true


# SOS API snapshot cache retention policy for history-integrity:
#   none    = never keep canonical snapshot files after hashing/counting
#   changed = keep changed/reappeared snapshots only (default)
#   all     = keep every successful snapshot (useful for CIC-Test debugging)
UK_AQ_HISTORY_INTEGRITY_KEEP_API_SNAPSHOTS="all"

# Optional cooldown (minutes) for repeated SOS not-found station/day checks.
# 0 disables suppression. When >0, previously-missing station/day units are
# not re-fetched until cooldown has elapsed.
UK_AQ_HISTORY_INTEGRITY_SOS_NOT_FOUND_COOLDOWN_MINUTES=30

# Base URL for UK-AIR annual CSV downloads used by flat-file SOS mode.
UK_AQ_HISTORY_INTEGRITY_UK_AIR_FLAT_FILE_BASE_URL="https://uk-air.defra.gov.uk/datastore/data_files/site_data"

# Comma-separated pollutant codes counted from UK-AIR flat files.
UK_AQ_HISTORY_INTEGRITY_SOS_TARGET_POLLUTANTS="pm25,pm10,no2"
